{
  "name": "@petriflow/engine",
  "version": "0.1.3",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./analyse": {
      "types": "./dist/analyse.d.ts",
      "import": "./dist/analyse.js",
      "require": "./dist/analyse.cjs"
    },
    "./workflow": {
      "types": "./dist/workflow.d.ts",
      "import": "./dist/workflow.js",
      "require": "./dist/workflow.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    },
    "./decision": {
      "types": "./dist/decision.d.ts",
      "import": "./dist/decision.js",
      "require": "./dist/decision.cjs"
    }
  },
  "keywords": ["petri-net", "workflow", "state-machine", "formal-verification", "ai-agent", "guardrails"],
  "files": ["dist", "README.md"],
  "scripts": {
    "test": "bun test",
    "build": "tsup",
    "check": "tsc --noEmit",
    "lint": "oxlint src/"
  },
  "dependencies": {
    "filtrex": "^3.1.0",
    "petri-ts": "^0.2.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joshuaisaact/petri-flow.git",
    "directory": "packages/engine"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "typescript": "^5.7",
    "@types/bun": "^1"
  }
}
